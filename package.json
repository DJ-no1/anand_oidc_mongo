{
  "name": "anand-oidc-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"pnpm --prefix backend start\" \"pnpm --prefix frontend start\"",
    "dev": "concurrently \"pnpm --prefix backend dev\" \"pnpm --prefix frontend dev\"",
    "backend": "pnpm --prefix backend dev",
    "frontend": "pnpm --prefix frontend dev",
    "install-all": "pnpm install && pnpm --prefix backend install && pnpm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
